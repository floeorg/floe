type Route = | Home
    | Profile { id: string }
    | NotFound

let route = Home

let _page = match route {
    Home -> "home",
    Profile(id) -> id,
    NotFound -> "404",
}

// Match with guards
type User = | Adult { age: number }
    | Child { age: number }

let user = Adult(age: 25)

let _label = match user {
    Adult(age) when age >= 65 -> "senior",
    Adult(age) -> "adult",
    Child(age) when age < 5 -> "toddler",
    Child(age) -> "child",
}

// Guard without bindings
let n = 42
let _category = match n {
    1..10 -> "low",
    _ when n > 100 -> "high",
    _ -> "medium",
}
