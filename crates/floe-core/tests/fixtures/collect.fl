let validateName(name: string) -> Result<string, string> = {
    Ok(name)
}

let validateEmail(email: string) -> Result<string, string> = {
    Ok(email)
}

let validateAge(age: number) -> Result<number, string> = {
    Ok(age)
}

let validateForm(input: { name: string, email: string, age: number }) -> Result<{ name: string, email: string, age: number }, Array<string>> = {
    collect {
        let name = validateName(input.name)?
        let email = validateEmail(input.email)?
        let age = validateAge(input.age)?

        { name: name, email: email, age: age }
    }
}
