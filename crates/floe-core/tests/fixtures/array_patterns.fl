let items = [1, 2, 3]

let _result = match items {
    [] -> "empty",
    [only] -> only,
    [first, ..rest] -> first,
}

// Two-element exact match
let pair = [10, 20]
let _sum = match pair {
    [a, b] -> a + b,
    _ -> 0,
}

// Rest pattern with multiple leading elements
let _head = match items {
    [a, b, ..rest] -> a + b,
    _ -> 0,
}
