// Trait definition with method signatures
trait Display {
  let display(self) -> string
}

// Trait with multiple methods and a default implementation
trait Eq {
  let eq(self, other: string) -> boolean
  let neq(self, other: string) -> boolean = {
    !(self |> eq(other))
  }
}

// Type definition
type User = {
  name: string,
  age: number
}

// Implementing a trait for a type
for User: Display {
  let display(self) -> string = {
    `${self.name} (${self.age})`
  }
}

// Implementing another trait
for User: Eq {
  let eq(self, other: string) -> boolean = {
    self.name == other
  }
}

// Regular for block (no trait) still works
for User {
  let greet(self, greeting: string) -> string = {
    `${greeting}, ${self.name}!`
  }
}
