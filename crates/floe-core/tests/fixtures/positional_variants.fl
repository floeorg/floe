// Positional variant fields — parens syntax

type Shape = | Circle(number)
    | Rect(number, number)
    | Point

// Construction

let c = Circle(5)

let r = Rect(10, 20)

let p = Point

// Pattern matching

let describe(s: Shape) -> string = {
    match s {
        Circle(radius) -> `circle r=${radius}`,
        Rect(w, h) -> `rect ${w}x${h}`,
        Point -> "point",
    }
}

let _d = describe(c)

// Mixed: positional and named in same union

type Result2 = | Ok2(string)
    | Err2 { code: number, message: string }

let _ok = Ok2("hello")

let _err = Err2(code: 404, message: "not found")

let _msg = match _ok {
    Ok2(val) -> val,
    Err2 { code, message } -> `${code}: ${message}`,
}

// Named-variant patterns also support renaming: `field: newName`.

let _msg2 = match _err {
    Ok2(val) -> val,
    Err2 { code: c, message: m } -> `${c}: ${m}`,
}
