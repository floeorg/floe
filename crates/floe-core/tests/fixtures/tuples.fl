// Tuple construction
let point = (10, 20)
let entry = ("key", 42)
let triple = (1, "two", true)

// Tuple type annotations
let origin: (number, number) = (0, 0)

// Tuple destructuring
let (x, y) = point

// Tuple in function return type
let divmod(a: number, b: number) -> (number, number) = {
  (a / b, a % b)
}

// Tuple in match
let describe(pair: (number, number)) -> string = {
  match pair {
    (0, 0) -> "origin",
    (_, 0) -> "on x-axis",
    (0, _) -> "on y-axis",
    (a, b) -> `(${a}, ${b})`,
  }
}
