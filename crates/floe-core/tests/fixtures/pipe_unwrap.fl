let validate(s: string) -> Result<string, string> = {
    Ok(s)
}

let format(s: string) -> Result<string, string> = {
    Ok(s)
}

let _testPipeUnwrap() -> Result<string, string> = {
    "hello" |> validate?
}

let _testPipeChainUnwrap() -> Result<string, string> = {
    "hello" |> validate |> format?
}

let _testPipeOptionUnwrap() -> Option<number> = {
    [1, 2, 3] |> Array.head?
}

let _testPipeUnwrapOp() -> Result<string, string> = {
    "hello" |>? validate
}

let _testPipeUnwrapOpChain() -> Result<string, string> = {
    "hello" |>? validate |>? format
}

let _testPipeUnwrapOpMixed() -> Result<string, string> = {
    "hello" |> validate |>? format
}

let _testPipeUnwrapOpOption() -> Option<number> = {
    [1, 2, 3] |>? Array.head
}
