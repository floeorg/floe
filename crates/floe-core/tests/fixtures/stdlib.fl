// ── Array ────────────────────────────────────────────────────
let _sorted = Array.sort([3, 1, 2])
let _sorted_by = Array.sortBy([3, 1, 2], (n) -> n)
let _mapped = Array.map([1, 2, 3], (n) -> n * 2)
let _filtered = Array.filter([1, 2, 3, 4], (n) -> n > 2)
let _found = Array.find([1, 2, 3], (n) -> n == 2)
let _found_idx = Array.findIndex([1, 2, 3], (n) -> n == 2)
let _flat_mapped = Array.flatMap([1, 2], (n) -> [n, n * 10])
let _at = Array.at([1, 2, 3], 1)
let _has = Array.contains([1, 2, 3], 2)
let _first = Array.head([1, 2, 3])
let _last_item = Array.last([1, 2, 3])
let _taken = Array.take([1, 2, 3, 4, 5], 3)
let _dropped = Array.drop([1, 2, 3, 4, 5], 2)
let _reversed = Array.reverse([1, 2, 3])
let _reduced = Array.reduce([1, 2, 3], 0, (acc, n) -> acc + n)
let _len = Array.length([1, 2, 3])
let _zipped = Array.zip([1, 2], ["a", "b"])

// ── Option ──────────────────────────────────────────────────
let _opt_mapped = Option.map(Some(42), (n) -> n * 2)
let _opt_flat = Option.flatMap(Some(42), (n) -> Some(n * 2))
let _opt_unwrap = Option.unwrapOr(None, 0)
let _opt_some = Option.isSome(Some(1))
let _opt_none = Option.isNone(None)
let _opt_to_res = Option.toResult(Some(42), "not found")
let _opt_or = Option.or(None, Some(99))
let _opt_values = Option.values([Some(1), None, Some(3)])

// ── Result ──────────────────────────────────────────────────
let _res_mapped = Result.map(Ok(42), (n) -> n + 1)
let _res_map_err = Result.mapErr(Err("bad"), (e) -> e)
let _res_flat = Result.flatMap(Ok(42), (n) -> Ok(n + 1))
let _res_unwrap = Result.unwrapOr(Err("fail"), 0)
let _res_ok = Result.isOk(Ok(1))
let _res_err = Result.isErr(Err("fail"))
let _res_to_opt = Result.toOption(Ok(42))
let _res_or = Result.or(Err("fail"), Ok(42))
let _res_values = Result.values([Ok(1), Err("x"), Ok(3)])
let _res_partition = Result.partition([Ok(1), Err("x"), Ok(3)])

// ── String ──────────────────────────────────────────────────
let _trimmed = String.trim("  hello  ")
let _trim_s = String.trimStart("  hello")
let _trim_e = String.trimEnd("hello  ")
let _split = String.split("a,b,c", ",")
let _replaced = String.replace("hello", "l", "r")
let _starts = String.startsWith("hello", "he")
let _ends = String.endsWith("hello", "lo")
let _str_has = String.contains("hello world", "world")
let _upper = String.toUpperCase("hello")
let _lower = String.toLowerCase("HELLO")
let _str_len = String.length("hello")
let _sliced = String.slice("hello", 1, 3)
let _pad_s = String.padStart("42", 5, "0")
let _pad_e = String.padEnd("hi", 5, "!")
let _repeated = String.repeat("ha", 3)

// ── Number ──────────────────────────────────────────────────
let _parsed = Number.parse("42")
let _clamped = Number.clamp(15, 0, 10)
let _finite = Number.isFinite(42)
let _integer = Number.isInteger(3.14)
let _fixed = Number.toFixed(3.14159, 2)
let _str_num = Number.toString(42)

// ── Console ────────────────────────────────────────────────
Console.log("hello")
Console.warn("warning")
Console.error("error")
Console.info("info")
Console.debug("debug")
Console.time("timer")
Console.timeEnd("timer")

// ── Math ───────────────────────────────────────────────────
let _floored = Math.floor(3.7)
let _ceiled = Math.ceil(3.2)
let _rounded = Math.round(3.5)
let _abs_val = Math.abs(-5)
let _min_val = Math.min(1, 2)
let _max_val = Math.max(1, 2)
let _power = Math.pow(2, 3)
let _root = Math.sqrt(16)
let _sgn = Math.sign(-5)
let _truncated = Math.trunc(3.9)
let _ln = Math.log(1)
let _sine = Math.sin(0)
let _cosine = Math.cos(0)
let _tangent = Math.tan(0)

// ── JSON ───────────────────────────────────────────────────
let _json_str = JSON.stringify([1, 2, 3])
let _json_parsed = JSON.parse("{}")

// ── Set ────────────────────────────────────────────────────
let _set = Set.fromArray([1, 2, 3])
let _set_arr = Set.toArray(_set)
let _set_added = Set.add(_set, 4)
let _set_removed = Set.remove(_set, 2)
let _set_has = Set.has(_set, 1)
let _set_size = Set.size(_set)
let _set_empty = Set.isEmpty(_set)
let _set2 = Set.fromArray([2, 3, 4])
let _set_union = Set.union(_set, _set2)
let _set_inter = Set.intersect(_set, _set2)
let _set_diff = Set.diff(_set, _set2)

// ── Date ──────────────────────────────────────────────────
let _date_now = Date.now()
let _date_from = Date.from("2024-01-15")
let _date_from_ms = Date.fromMillis(1705276800000)
let _date_year = Date.year(_date_now)
let _date_month = Date.month(_date_now)
let _date_day = Date.day(_date_now)
let _date_hour = Date.hour(_date_now)
let _date_minute = Date.minute(_date_now)
let _date_second = Date.second(_date_now)
let _date_millis = Date.millis(_date_now)
let _date_iso = Date.toIso(_date_now)

// ── Pipes with stdlib ───────────────────────────────────────
let _piped = [3, 1, 2] |> Array.sort
let _pipe_chain = [1, 2, 3, 4, 5]
  |> Array.filter((n) -> n > 2)
  |> Array.map((n) -> n * 10)
  |> Array.reverse

let _pipe_opt = Some(10) |> Option.map((n) -> n + 1)
let _pipe_str = "  hello  " |> String.trim
let _pipe_num = "42" |> Number.parse
let _pipe_date = Date.now() |> Date.toIso
