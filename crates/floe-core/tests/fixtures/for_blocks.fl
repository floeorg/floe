type User = {
  name: string,
  age: number,
  active: boolean
}

for User {
  let display(self) -> string = {
    `${self.name} (${self.age})`
  }

  let isAdult(self) -> boolean = {
    self.age >= 18
  }

  let greet(self, greeting: string) -> string = {
    `${greeting}, ${self.name}!`
  }
}

for Array<User> {
  let adults(self) -> Array<User> = {
    self |> filter(.age >= 18)
  }
}

// Type-directed pipe resolution: bare stdlib names work in pipes
let _filtered = [User(name: "Ryan", age: 25, active: true)]
  |> filter(.active)

// Disambiguation: `length` resolves to Array.length or String.length based on type
let _arrLen = [1, 2, 3] |> length
let _strLen = "hello" |> length
