type User = {
  name: string,
  age: number,
  active: bool
}

for User {
  fn display(self) -> string {
    `${self.name} (${self.age})`
  }

  fn isAdult(self) -> bool {
    self.age >= 18
  }

  fn greet(self, greeting: string) -> string {
    `${greeting}, ${self.name}!`
  }
}

for Array<User> {
  fn adults(self) -> Array<User> {
    self |> filter(.age >= 18)
  }
}

// Type-directed pipe resolution: bare stdlib names work in pipes
const names = [User(name: "Ryan", age: 25, active: true)]
  |> filter(.active)
  |> map(.name)
