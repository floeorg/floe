type User = { name: string; age: number; active: boolean };

function User__display(self: User): string {
  return `${self.name} (${self.age})`;
}
function User__isAdult(self: User): boolean {
  return self.age >= 18;
}
function User__greet(self: User, greeting: string): string {
  return `${greeting}, ${self.name}!`;
}

function Array_User__adults(self: Array<User>): Array<User> {
  return self.filter((_x) => _x.age >= 18);
}

