{
  "name": "tree-sitter-floe",
  "version": "0.1.0",
  "description": "Tree-sitter grammar for the Floe programming language",
  "main": "bindings/node",
  "scripts": {
    "generate": "tree-sitter generate",
    "test": "tree-sitter test",
    "build": "tree-sitter generate && tree-sitter build",
    "regen": "tree-sitter generate && tree-sitter test",
    "check": "tree-sitter generate && git diff --exit-code src/ && tree-sitter test"
  },
  "keywords": [
    "tree-sitter",
    "parser",
    "floe"
  ],
  "license": "MIT",
  "dependencies": {
    "nan": "^2.18.0"
  },
  "devDependencies": {
    "tree-sitter-cli": "^0.26.8"
  },
  "tree-sitter": [
    {
      "scope": "source.floe",
      "file-types": [
        "fl"
      ],
      "highlights": "queries/highlights.scm"
    }
  ]
}
