{
  "Function Declaration": {
    "prefix": "let",
    "body": [
      "let ${1:name}(${2:params}) -> ${3:ReturnType} = {",
      "\t$0",
      "}"
    ],
    "description": "Named function (def-form)"
  },
  "Export Function": {
    "prefix": "efn",
    "body": [
      "export let ${1:name}(${2:params}) -> ${3:ReturnType} = {",
      "\t$0",
      "}"
    ],
    "description": "Exported named function"
  },
  "Default Export": {
    "prefix": "edef",
    "body": ["export default ${1:name}"],
    "description": "Promote a named binding to the module's default export"
  },
  "Async Function": {
    "prefix": "afn",
    "body": [
      "async let ${1:name}(${2:params}) -> ${3:ReturnType} = {",
      "\t$0",
      "}"
    ],
    "description": "Async function (return type is wrapped in Promise<T>)"
  },
  "Match Expression": {
    "prefix": "match",
    "body": [
      "match ${1:expr} {",
      "\t${2:pattern} -> ${3:body},",
      "\t_ -> ${0:default},",
      "}"
    ],
    "description": "Match expression"
  },
  "Match with Guard": {
    "prefix": "matchw",
    "body": [
      "match ${1:expr} {",
      "\t${2:pattern} when ${3:condition} -> ${4:body},",
      "\t_ -> ${0:default},",
      "}"
    ],
    "description": "Match expression with guard"
  },
  "Match Result": {
    "prefix": "matchr",
    "body": [
      "match ${1:result} {",
      "\tOk(${2:value}) -> ${3:body},",
      "\tErr(${4:error}) -> ${0:errorBody},",
      "}"
    ],
    "description": "Match on Result"
  },
  "Match Option": {
    "prefix": "matcho",
    "body": [
      "match ${1:option} {",
      "\tSome(${2:value}) -> ${3:body},",
      "\tNone -> ${0:default},",
      "}"
    ],
    "description": "Match on Option"
  },
  "Type Record": {
    "prefix": "type",
    "body": [
      "type ${1:Name} = {",
      "\t${2:field}: ${3:Type},",
      "}"
    ],
    "description": "Record type declaration"
  },
  "Type Union": {
    "prefix": "union",
    "body": [
      "type ${1:Name} =",
      "\t| ${2:Variant1}",
      "\t| ${3:Variant2}"
    ],
    "description": "Union type declaration"
  },
  "Typealias": {
    "prefix": "typealias",
    "body": [
      "typealias ${1:Name} = ${0:Type}"
    ],
    "description": "Structural type alias"
  },
  "React Component": {
    "prefix": "comp",
    "body": [
      "export let ${1:Component}() -> JSX.Element = {",
      "\treturn <div>",
      "\t\t$0",
      "\t</div>",
      "}"
    ],
    "description": "React component"
  },
  "Import": {
    "prefix": "imp",
    "body": [
      "import { ${2:name} } from \"${1:module}\""
    ],
    "description": "Import statement"
  },
  "Pipe": {
    "prefix": "pipe",
    "body": [
      "${1:value} |> ${0:transform}"
    ],
    "description": "Pipe expression"
  },
  "Value Binding": {
    "prefix": "lt",
    "body": [
      "let ${1:name} = ${0:value}"
    ],
    "description": "Value binding"
  },
  "Newtype": {
    "prefix": "newtype",
    "body": [
      "type ${1:Name} = ${1:Name}(${2:string})"
    ],
    "description": "Newtype wrapper"
  },
  "Opaque Type": {
    "prefix": "opaque",
    "body": [
      "opaque type ${1:Name} = ${1:Name}(${2:string})"
    ],
    "description": "Opaque type"
  },
  "For Block": {
    "prefix": "for",
    "body": [
      "for ${1:Type} {",
      "\texport let ${2:name}(self) -> ${3:ReturnType} = {",
      "\t\t$0",
      "\t}",
      "}"
    ],
    "description": "For block - register inherent pipe-functions on a type"
  },
  "Import For Type": {
    "prefix": "impfor",
    "body": [
      "import { for ${2:Type} } from \"${1:module}\""
    ],
    "description": "Import a for-block's inherent methods by type"
  },
  "Trait Declaration": {
    "prefix": "trait",
    "body": [
      "trait ${1:Name} {",
      "\tlet ${2:method}(self) -> ${3:ReturnType}",
      "}"
    ],
    "description": "Trait declaration"
  },
  "Trait Implementation": {
    "prefix": "impl",
    "body": [
      "impl ${1:Trait} for ${2:Type} {",
      "\tlet ${3:method}(self) -> ${4:ReturnType} = {",
      "\t\t$0",
      "\t}",
      "}"
    ],
    "description": "Trait implementation"
  },
  "Closure": {
    "prefix": "closure",
    "body": [
      "(${1:params}) -> ${0:expr}"
    ],
    "description": "Anonymous lambda expression"
  },
  "Tap Debug": {
    "prefix": "tap",
    "body": [
      "tap(${1:Console.log})"
    ],
    "description": "Tap for pipeline debugging"
  },
  "Test Block": {
    "prefix": "test",
    "body": [
      "test \"${1:name}\" {",
      "\tassert ${0:expression}",
      "}"
    ],
    "description": "Inline test block"
  },
  "Collect Block": {
    "prefix": "collect",
    "body": [
      "collect {",
      "\tlet ${1:name} = ${2:expr}?",
      "\t$0",
      "}"
    ],
    "description": "Collect block for error accumulation"
  },
  "Todo Placeholder": {
    "prefix": "todo",
    "body": [
      "todo"
    ],
    "description": "Placeholder that panics at runtime (type never)"
  },
  "Unreachable": {
    "prefix": "unreachable",
    "body": [
      "unreachable"
    ],
    "description": "Assert unreachable code path (type never)"
  },
  "Mock": {
    "prefix": "mock",
    "body": [
      "mock<${1:Type}>"
    ],
    "description": "Generate test data from a type definition"
  },
  "Mock with Overrides": {
    "prefix": "mocko",
    "body": [
      "mock<${1:Type}>(${2:field}: ${0:value})"
    ],
    "description": "Generate test data with field overrides"
  },
  "Use Bind": {
    "prefix": "use",
    "body": [
      "use ${1:binding} <- ${0:expr}"
    ],
    "description": "Use bind (callback flattening) — unwraps into `binding` or bails via the guard function"
  },
  "Use Guard (Bool)": {
    "prefix": "useb",
    "body": [
      "use <- Bool.guard(${1:condition}, ${0:fallback})"
    ],
    "description": "Boolean guard — continues if condition is true, returns `fallback` otherwise"
  },
  "Use Guard (Option)": {
    "prefix": "useo",
    "body": [
      "use ${1:value} <- Option.guard(${2:option}, ${0:fallback})"
    ],
    "description": "Option guard — unwraps `Some` into `value`, returns `fallback` on `None`"
  },
  "Use Guard (Result)": {
    "prefix": "user",
    "body": [
      "use ${1:value} <- Result.guard(${2:result}, (${3:e}) -> ${0:fallback})"
    ],
    "description": "Result guard — unwraps `Ok` into `value`, runs the error handler on `Err`"
  }
}
