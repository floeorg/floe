    match len {
//  ^^^^^ keyword.control.floe
        0 -> Empty,
//        ^^ keyword.operator.arrow.floe
    }
}

let handleDelete(id: string) = {
// <-- storage.type.floe
// ^^^^^^^^^^^^ entity.name.function.floe

    return <div>
//          ^^^ entity.name.tag.floe
        <button onClick={handleAdd}>
//       ^^^^^^ entity.name.tag.floe
//              ^^^^^^^ entity.other.attribute-name.floe
        </button>
